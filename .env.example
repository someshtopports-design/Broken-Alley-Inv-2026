# Environment variables for Broken-Alley Inventory App
# Copy this to .env.local and fill in your Vercel Postgres credentials

# Vercel Postgres (from Vercel dashboard → Storage → your DB → .env.local)
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""

# Optional: direct postgres url for local dev (e.g. postgresql://user:password@localhost:5432/brokenalley)
# DATABASE_URL=""
